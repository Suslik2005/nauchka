#include <Servo.h>

// ========== ДЖОЙСТИКИ И СЕРВО ==========
Servo servo1_X, servo1_Y, servo2_X, servo2_Y;
const int pinJoy1_X = A0, pinJoy1_Y = A1;
const int pinJoy2_X = A2, pinJoy2_Y = A3;
const int pinServo1_X = 10, pinServo1_Y = 13;
const int pinServo2_X = 4, pinServo2_Y = 7;

// ========== ACS712 НА A4 ==========
const int pinACS712 = A4;
const float VCC = 5.0;
const float zeroPoint = 2.5075;
const float sensitivity = 0.185;

// ========== ПАРАМЕТРЫ АККУМУЛЯТОРА ==========
const float batteryCapacity_mAh = 1000.0;
const float lowBatteryPercent = 10.0;
float lowBatteryThreshold_mAh = batteryCapacity_mAh * lowBatteryPercent / 100.0;

// ========== СКОЛЬЗЯЩЕЕ СРЕДНЕЕ ==========
const int MA_SIZE = 3;
float maBuffer[MA_SIZE] = {0};
int maIndex = 0;
bool maReady = false;

// ========== ДЛЯ РАСЧЁТА ЁМКОСТИ ==========
float consumed_mAh = 0.0;
unsigned long previousMillis = 0;

// ========== ДЛЯ ПРЕДУПРЕЖДЕНИЯ ==========
bool lowBatteryAlerted = false;   // было ли уже выведено предупреждение при текущем состоянии ниже порога

float readCurrent() {
  long sum = 0;
  for (int i = 0; i < 10; i++) sum += analogRead(pinACS712);
  float voltage = (sum / 10.0) * (VCC / 1023.0);
  return (voltage - zeroPoint) / sensitivity;
}

float applyMovingAverage(float newValue) {
  maBuffer[maIndex] = newValue;
  maIndex = (maIndex + 1) % MA_SIZE;
  
  if (maIndex == 0) maReady = true;
  
  float sum = 0;
  int count = maReady ? MA_SIZE : maIndex + 1;
  
  for (int i = 0; i < count; i++) sum += maBuffer[i];
  return sum / count;
}

// Функция предупреждения (один раз при переходе ниже порога)
void alert(float remaining_mAh) {
  bool lowBattery = (remaining_mAh < lowBatteryThreshold_mAh);
  
  if (lowBattery && !lowBatteryAlerted) {
    // Первое пересечение порога — выводим предупреждение
    Serial.print("⚠️ НИЗКИЙ ЗАРЯД! Осталось: ");
    Serial.print(remaining_mAh, 1);
    Serial.print(" мА·ч (");
    Serial.print((remaining_mAh / batteryCapacity_mAh) * 100.0, 1);
    Serial.println("%) ⚠️");
    lowBatteryAlerted = true;
  } else if (!lowBattery) {
    // Если заряд поднялся выше порога, сбрасываем флаг, чтобы при новом падении предупреждение повторилось
    lowBatteryAlerted = false;
  }
}

int val1_X, val1_Y, val2_X, val2_Y;
float currentA = 0.0, currentSmoothed = 0.0;

void setup() {
  Serial.begin(9600);
  
  servo1_X.attach(pinServo1_X); servo1_Y.attach(pinServo1_Y);
  servo2_X.attach(pinServo2_X); servo2_Y.attach(pinServo2_Y);
  
  servo1_X.write(90); servo1_Y.write(90);
  servo2_X.write(90); servo2_Y.write(90);
  
  previousMillis = millis();
  delay(1000);
}

void loop() {
  unsigned long currentMillis = millis();
  float deltaSec = (currentMillis - previousMillis) / 1000.0;
  previousMillis = currentMillis;
  
  // Джойстики
  val1_X = analogRead(pinJoy1_X); val1_Y = analogRead(pinJoy1_Y);
  servo1_X.write(map(val1_X, 0, 1023, 0, 180));
  servo1_Y.write(map(val1_Y, 0, 1023, 0, 180));
  
  val2_X = analogRead(pinJoy2_X); val2_Y = analogRead(pinJoy2_Y);
  servo2_X.write(map(val2_X, 0, 1023, 0, 180));
  servo2_Y.write(map(val2_Y, 0, 1023, 0, 180));
  
  // Ток
  currentA = readCurrent();
  currentSmoothed = applyMovingAverage(currentA);
  
  // --- РАСЧЁТ ЁМКОСТИ В мА·ч ---
  if (currentSmoothed > 0) {
    consumed_mAh += currentSmoothed * (deltaSec / 3600.0) * 1000.0;
  }
  if (consumed_mAh > batteryCapacity_mAh) consumed_mAh = batteryCapacity_mAh;
  
  // --- ОСТАВШАЯСЯ ЁМКОСТЬ ---
  float remaining_mAh = batteryCapacity_mAh - consumed_mAh;
  if (remaining_mAh < 0) remaining_mAh = 0;
  
  // --- ПРЕДУПРЕЖДЕНИЕ (один раз) ---
  alert(remaining_mAh);
  
  // --- ВЫВОД В SERIAL PLOTTER ---
  Serial.print(currentA, 2); Serial.print(",");
  Serial.print(currentSmoothed, 2); Serial.print(",");
  Serial.print(consumed_mAh, 1); Serial.print(",");
  Serial.println(remaining_mAh, 1);
  
  delay(60);
}
